{
  "name": "C4CV2OpportunityServiceExtension",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "repository": "<Add your repository here>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@sap-cloud-sdk/connectivity": "^3.26.4",
    "@sap-cloud-sdk/http-client": "^3.26.4",
    "@sap-cloud-sdk/resilience": "^3.26.4",
    "@sap/cds": "^8",
    "@sap/xssec": "^4",
    "axios": "^1.7.9",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.8.0",
    "@cap-js/sqlite": "^1",
    "@sap/cds-dk": "^8",
    "@sap/dev-cap-tools": "^1.31.0"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "cds": {
    "requires": {
      "[development]": {
        "auth": {
          "kind": "mocked"
        }
      },
      "[production]": {
        "auth": "xsuaa"
      },
      "connectivity": true,
      "destinations": true,
      "Account.Service": {
        "kind": "rest",
        "model": "srv/external/SalesSvcCloudV2_accountService",
        "credentials": {
          "destination": "C4C_V2_API",
          "path": "/sap/c4c/api/v1/account-service"
        }
      }
    }
  }
}